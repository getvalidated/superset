# Copy to .env (git-ignored) and fill in. Everything here is optional if you
# use `docker exec -it superset-sandbox-host superset login` for auth.

# Superset org the host registers under. Omit to take it from `superset login`.
#ORGANIZATION_ID=

# Static session token (testing only — expires; prefer `superset login`).
#AUTH_TOKEN=

#SUPERSET_API_URL=https://api.superset.sh
#RELAY_URL=https://relay.superset.sh

# Key file for the restricted GCP service account (created outside the repo).
#SANDBOX_GCP_KEY_FILE=~/.superset-sandbox/gcp/superset-sandbox-host.json

# Fine-grained PAT restricted to the repos sandbox agents may touch
# (contents: read/write, pull requests: read/write). Do NOT use a classic
# all-repos token — that would defeat the sandbox.
#SANDBOX_GITHUB_TOKEN=

# Anthropic key for agents running inside the sandbox. Consider a
# workspace-scoped key with a spend limit.
#SANDBOX_ANTHROPIC_API_KEY=

# Local debug port mapping (127.0.0.1 only) and resource limits.
#SANDBOX_HOST_PORT=14879
#SANDBOX_CPUS=4
#SANDBOX_MEM_LIMIT=8g
