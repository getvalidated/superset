{
	"extends": "@superset/typescript/base.json",
	"compilerOptions": {
		"jsx": "react-jsx",
		"types": ["@cloudflare/workers-types"],
		"lib": ["ES2022", "ES2021.String"],
		"moduleResolution": "Bundler",
		"module": "ESNext",
		"noEmit": true
	},
	"include": ["src/**/*.ts"],
	"exclude": ["node_modules"]
}
